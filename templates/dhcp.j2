# -----------------------------------------------------------------------------
# --- DNSMASQ ---
# -----------------------------------------------------------------------------

config dnsmasq 'main'
	option port '0'
{% for interface in network.interfaces if interface.dhcp %}
	list interface '{{ interface.name }}'
{% endfor %}

# -----------------------------------------------------------------------------
# --- DHCP POOLS ---
# -----------------------------------------------------------------------------

{% for interface in network.interfaces if interface.dhcp %}
config dhcp '{{ interface.name }}'
	option interface '{{ interface.name }}'
	option start '100'
	option limit '150'
	option leasetime '12h'
	option dhcpv4 'server'
	list dhcp_option '6,{{ interface.dns }}'

{% endfor %}
